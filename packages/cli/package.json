    "open": "^10.1.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@invoice/core": "workspace:*",
    "@invoice/dashboard": "workspace:*",
    "@invoice/renderer": "workspace:*",
    "@invoice/shared": "workspace:*",
    "@types/node": "^22.0.0",
